{
  "manifest_version": 3,
  "name": "ტესტ-ქეისის ჩამწერი",
  "version": "1.0.5",
  "description": "ჩაწერს მომხმარებლის ქმედებებს და ქმნის სტრუქტურირებულ ტესტ-ქეისებს QA ავტომატიზაციისთვის.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "panel/panel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["i18n.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "devtools_page": "devtools.html"
}
